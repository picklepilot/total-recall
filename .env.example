# Copy to .env — Firebase Console → Project settings → Your apps (Web).

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin: Console → Project settings → Service accounts → Generate new private key.
# Paste the ENTIRE JSON as a single line (or use your host's "JSON secret" feature).
# Required for /api/chat and /api/link-preview to verify Google sign-in.
NUXT_FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: comma-separated Google account emails allowed to use this deployment.
# If set, only these accounts can call protected APIs (strongly recommended for a personal app).
# Example: NUXT_ALLOWED_AUTH_EMAILS=you@gmail.com
NUXT_ALLOWED_AUTH_EMAILS=

# Gemini (Google AI Studio). Server-only: chat, streaming chat, embeddings for vector search
# (`text-embedding-004` via the same Generative Language API).
NUXT_GEMINI_API_KEY=
