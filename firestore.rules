rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /entries/{entryId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'userId', 'contentJson', 'contentText', 'url', 'linkPreview', 'tags', 'createdAt'
        ])
        && !request.resource.data.keys().hasAny(['embedding']);
      // Clients cannot change server-managed vector field; Admin SDK bypasses these rules.
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['embedding']);
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
